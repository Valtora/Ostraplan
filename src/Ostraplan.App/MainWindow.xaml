<Window x:Class="Ostraplan.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Ostraplan.App"
        Title="Ostraplan" Width="1440" Height="920"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource WindowBg}"
        TextElement.Foreground="{DynamicResource Ink}">
    <Window.Resources>
        <Style x:Key="SideHeader" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Dim}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,10,0,4"/>
        </Style>
        <Style x:Key="SideValue" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Ink}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
        <!-- Toolbar group separator -->
        <Style x:Key="ToolSep" TargetType="Border">
            <Setter Property="Width" Value="1"/>
            <Setter Property="Margin" Value="7,3"/>
            <Setter Property="Background" Value="{DynamicResource PanelBorder}"/>
        </Style>
        <DataTemplate x:Key="PartTemplate">
            <Grid Margin="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="46"/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <Border Width="42" Height="42" Background="#33808080" CornerRadius="3">
                    <Image Source="{Binding Thumb}" Stretch="Uniform" Margin="3"
                           RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                </Border>
                <StackPanel Grid.Column="1" Margin="7,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Friendly}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                    <TextBlock Text="{Binding Sub}" FontSize="11" Opacity="0.6" TextTrimming="CharacterEllipsis"/>
                </StackPanel>
            </Grid>
        </DataTemplate>
    </Window.Resources>

    <DockPanel>
        <Border DockPanel.Dock="Top" Background="{DynamicResource PanelBg}" Padding="8,6">
            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <!-- File -->
                    <Button x:Name="BtnNew" Content="New" Padding="10,3" Margin="0,0,3,0" Click="OnNewClick"
                            ToolTip="New ship (Ctrl+N) — starts with a docking port at 0,0"/>
                    <Button x:Name="BtnOpen" Content="Open…" Padding="10,3" Margin="0,0,3,0" Click="OnOpenClick"
                            ToolTip="Open an .oplan design (Ctrl+O)"/>
                    <Button x:Name="BtnSave" Content="Save" Padding="10,3" Margin="0,0,3,0" Click="OnSaveClick"
                            ToolTip="Save (Ctrl+S)"/>
                    <Button x:Name="BtnSaveAs" Content="Save As…" Padding="10,3" Margin="0,0,3,0" Click="OnSaveAsClick"
                            ToolTip="Save As (Ctrl+Shift+S)"/>
                    <Button x:Name="BtnImport" Content="Import ▾" Padding="10,3" Margin="0,0,3,0" Click="OnImportClick"
                            ToolTip="Start a design from an existing ship — an in-game ship or a save game"/>
                    <Button x:Name="BtnExport" Content="Export…" Padding="10,3" Margin="0,0,3,0" Click="OnExportClick"
                            ToolTip="Export the design as a spawnable local data mod (data/ships) with precomputed rooms &amp; rating"/>
                    <Button x:Name="BtnUpdateSave" Content="Update Ship in Save…" Padding="10,3" Margin="0,0,3,0" Click="OnUpdateSaveClick"
                            IsEnabled="False"
                            ToolTip="Write this edited ship back into a COPY of the save it came from, keeping crew and cargo (enabled only for a design imported for editing)"/>

                    <Border Style="{StaticResource ToolSep}"/>

                    <!-- Edit -->
                    <Button x:Name="BtnUndo" Content="Undo" Padding="10,3" Margin="0,0,3,0" Click="OnUndoClick"
                            ToolTip="Undo (Ctrl+Z)"/>
                    <Button x:Name="BtnRedo" Content="Redo" Padding="10,3" Margin="0,0,3,0" Click="OnRedoClick"
                            ToolTip="Redo (Ctrl+Y)"/>

                    <Border Style="{StaticResource ToolSep}"/>

                    <!-- Design -->
                    <Button x:Name="BtnTheme" Content="Ship Re-skin…" Padding="10,3" Margin="0,0,3,0" Click="OnThemeClick"
                            ToolTip="Re-skin every wall and floor to a chosen style (sprites only — rooms &amp; rating are unaffected)"/>
                    <Button x:Name="BtnSnapshot" Content="Snapshot…" Padding="10,3" Margin="0,0,3,0" Click="OnSnapshotClick"
                            ToolTip="Save a PNG image of the ship (no grid or UI) to share or reference"/>

                    <Border Style="{StaticResource ToolSep}"/>

                    <!-- Analyse -->
                    <Button x:Name="BtnRating" Content="Ship Rating" Padding="10,3" Margin="0,0,3,0" Click="OnShipRatingClick"
                            Background="{DynamicResource AccentBg}" Foreground="{DynamicResource AccentText}"
                            ToolTip="Analyse rooms, airtightness, certification and the Ship Rating for the current design"/>
                    <Button x:Name="BtnMaterials" Content="Bill of Materials" Padding="10,3" Margin="0,0,3,0" Click="OnMaterialsClick"
                            ToolTip="Bill of materials — how many install kits of each part the design needs (whole ship, or the current selection)"/>

                    <Border Style="{StaticResource ToolSep}"/>

                    <!-- View -->
                    <Button x:Name="BtnFit" Content="Fit" Padding="10,3" Margin="0,0,3,0" Click="OnFitClick"
                            ToolTip="Fit the view to the ship (F)"/>
                    <Button x:Name="BtnSym" Content="Symmetry: Off" Padding="10,3" Margin="0,0,3,0" Click="OnSymClick"
                            ToolTip="Cycle symmetry: Off → Vertical → Horizontal → Both (M). Axes centre on the tile under the cursor when switching on."/>
                </StackPanel>

                <!-- Right side (added right-to-left) -->
                <Button x:Name="BtnHelp" Content="Help" DockPanel.Dock="Right" Padding="10,3" Margin="6,0,0,0"
                        Click="OnHelpClick" ToolTip="Controls &amp; keybinds (F1)"/>
                <ComboBox x:Name="CmbTheme" DockPanel.Dock="Right" Width="150" Margin="6,0,0,0"
                          VerticalAlignment="Center" SelectionChanged="OnThemeModeChanged"
                          ToolTip="App appearance: follow Windows, or force light/dark (the ship canvas stays dark either way)">
                    <ComboBoxItem Content="Theme: System"/>
                    <ComboBoxItem Content="Theme: Light"/>
                    <ComboBoxItem Content="Theme: Dark"/>
                </ComboBox>
                <Button x:Name="BtnUpdate" DockPanel.Dock="Right" Padding="10,3" Margin="6,0,0,0"
                        Visibility="Collapsed" Click="OnUpdateClick"
                        Background="{DynamicResource AccentBg}" Foreground="{DynamicResource AccentText}"
                        ToolTip="A newer release is available — click to open the download page"/>
                <TextBlock x:Name="TxtVersion" DockPanel.Dock="Right" VerticalAlignment="Center"
                           Foreground="{DynamicResource Dim}" Margin="12,0,0,0"/>
                <TextBlock x:Name="TxtWarnings" DockPanel.Dock="Right" VerticalAlignment="Center"
                           Foreground="{DynamicResource Warn}" Margin="12,0,0,0"/>
                <TextBlock x:Name="TxtDoc" VerticalAlignment="Center" HorizontalAlignment="Center"
                           Foreground="{DynamicResource Ink}" FontWeight="SemiBold"/>
            </DockPanel>
        </Border>

        <StatusBar DockPanel.Dock="Bottom" Background="{DynamicResource PanelBg}" Foreground="{DynamicResource Dim}">
            <StatusBarItem><TextBlock x:Name="TxtCell" Text="—" Width="110"/></StatusBarItem>
            <Separator/>
            <StatusBarItem><TextBlock x:Name="TxtZoom" Text="" Width="90"/></StatusBarItem>
            <Separator/>
            <StatusBarItem><TextBlock x:Name="TxtParts" Text=""/></StatusBarItem>
            <Separator/>
            <StatusBarItem><TextBlock x:Name="TxtGhost" Text="" FontWeight="SemiBold" Foreground="{DynamicResource Bad}"/></StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock x:Name="TxtHint" Opacity="0.7"
                           Text="drag paint · Shift+drag fill · Ctrl+Shift hollow · RMB menu · R rotate · Q/E view · M symmetry · WASD pan · F1 help"/>
            </StatusBarItem>
        </StatusBar>

        <Border DockPanel.Dock="Left" Width="330" Background="{DynamicResource PanelBg}" Padding="8"
                BorderBrush="{DynamicResource PanelBorder}" BorderThickness="0,0,1,0">
            <DockPanel>
                <TextBox x:Name="TxtSearch" DockPanel.Dock="Top" Margin="0,0,0,6" Padding="4,3"
                         TextChanged="OnSearchChanged" ToolTip="Search parts by name"/>
                <TabControl x:Name="Tabs" Background="Transparent" BorderThickness="0"/>
            </DockPanel>
        </Border>

        <Border DockPanel.Dock="Right" Width="270" Background="{DynamicResource PanelBg}" Padding="12,8"
                BorderBrush="{DynamicResource PanelBorder}" BorderThickness="1,0,0,0">
            <StackPanel>
                <TextBlock Text="PROBLEMS" Style="{StaticResource SideHeader}" Margin="0,0,0,4"/>
                <StackPanel x:Name="ProblemsPanel"/>
                <Separator Margin="0,10,0,0" Background="{DynamicResource PanelBorder}"/>
                <TextBlock Text="PART" Style="{StaticResource SideHeader}"/>
                <TextBlock x:Name="InsFriendly" Style="{StaticResource SideValue}" FontSize="15" FontWeight="SemiBold" Text="—"/>
                <TextBlock x:Name="InsInternal" Style="{StaticResource SideValue}" Opacity="0.6" FontSize="11"/>
                <StackPanel x:Name="DescBlock" Visibility="Collapsed">
                    <TextBlock Text="DESCRIPTION" Style="{StaticResource SideHeader}"/>
                    <ScrollViewer MaxHeight="120" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <TextBlock x:Name="InsDesc" Style="{StaticResource SideValue}" FontSize="12"
                                   TextWrapping="Wrap" Opacity="0.85"/>
                    </ScrollViewer>
                </StackPanel>
                <TextBlock Text="CATEGORY" Style="{StaticResource SideHeader}"/>
                <TextBlock x:Name="InsCategory" Style="{StaticResource SideValue}"/>
                <TextBlock Text="FOOTPRINT" Style="{StaticResource SideHeader}"/>
                <TextBlock x:Name="InsSize" Style="{StaticResource SideValue}"/>
                <StackPanel x:Name="PriceBlock" Visibility="Collapsed">
                    <TextBlock Text="BASE VALUE" Style="{StaticResource SideHeader}"/>
                    <TextBlock x:Name="InsPrice" Style="{StaticResource SideValue}"/>
                </StackPanel>
                <TextBlock Text="SOURCE" Style="{StaticResource SideHeader}"/>
                <TextBlock x:Name="InsOrigin" Style="{StaticResource SideValue}"/>
                <TextBlock Text="INSTALL MATERIALS" Style="{StaticResource SideHeader}"/>
                <TextBlock x:Name="InsInputs" Style="{StaticResource SideValue}" FontSize="12"/>
            </StackPanel>
        </Border>

        <Grid>
            <local:ShipCanvas x:Name="Board"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,10,14,0">
                <Border x:Name="BadgeWarning" Background="#F0E0A34E" CornerRadius="14" Height="28" MinWidth="28"
                        Visibility="Collapsed" Margin="8,0,0,0">
                    <TextBlock x:Name="BadgeWarningText" Foreground="#FF23262C" FontWeight="Bold" FontSize="14"
                               HorizontalAlignment="Center" VerticalAlignment="Center" Margin="9,0"/>
                </Border>
                <Border x:Name="BadgeBlocking" Background="#F0D64545" CornerRadius="14" Height="28" MinWidth="28"
                        Visibility="Collapsed" Margin="8,0,0,0">
                    <TextBlock x:Name="BadgeBlockingText" Foreground="White" FontWeight="Bold" FontSize="14"
                               HorizontalAlignment="Center" VerticalAlignment="Center" Margin="9,0"/>
                </Border>
            </StackPanel>
            <Border x:Name="LoadingOverlay" Background="#DD1A1C20">
                <TextBlock x:Name="TxtLoading" Text="Locating Ostranauts…" Foreground="#FFD8DDE4"
                           FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
        </Grid>
    </DockPanel>
</Window>
